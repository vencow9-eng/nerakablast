generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  MEMBER
}

enum DeviceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum BlastStatus {
  PENDING
  RUNNING
  STOPPED
  COMPLETED
  FAILED
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(MEMBER)
  isActive  Boolean  @default(true)
  isStaff   Boolean  @default(false)
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent  User?  @relation("StaffMembers", fields: [parentId], references: [id])
  members User[] @relation("StaffMembers")

  templates Template[]
  targets   Target[]
  devices   Device[]
  blasts    Blast[]
}

model Template {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  title     String
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id])
  blasts Blast[]
}

model Target {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  name      String
  phones    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id])
  blasts Blast[]
}

model Device {
  id        Int          @id @default(autoincrement())
  userId    Int
  sessionId String       @unique
  status    DeviceStatus @default(DISCONNECTED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Blast {
  id         Int         @id @default(autoincrement())
  userId     Int
  templateId Int
  targetId   Int
  total      Int         @default(0)
  success    Int         @default(0)
  failed     Int         @default(0)
  status     BlastStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  speed String @default("medium")
  delayMs Int @default(15000)

  user     User     @relation(fields: [userId], references: [id])
  template Template @relation(fields: [templateId], references: [id])
  target   Target   @relation(fields: [targetId], references: [id])
}
